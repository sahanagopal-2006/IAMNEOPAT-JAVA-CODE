import java.util.Scanner;
class main{
    public static void main(String args[]){
        int n,d=0;
        Scanner sc= new Scanner (System.in);
        n=sc.nextInt();
        if(n==0){
            d=1;
            
        }else{
            do{
                n=n/10;
                d=d+1;
                
            }while(n!=0);
            
        }
        System.out.println(d);
        sc.close();
    }
}
